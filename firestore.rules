rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserDoc().data.status == 'active';
    }

    function hasRole(role) {
      return isActiveUser()
        && getUserDoc().data.roles.hasAny([role]);
    }

    function hasAnyRole(roles) {
      return isActiveUser()
        && getUserDoc().data.roles.hasAny(roles);
    }

    function canWrite(roles) {
      return hasAnyRole(roles);
    }

    function canRead(roles) {
      return hasAnyRole(roles);
    }

    // Any active user holding at least one reviewer or lead role
    function isActiveReviewer() {
      return isActiveUser()
        && getUserDoc().data.roles.hasAny(
             ['signal-reviewer', 'discovery-reviewer', 'scoring-reviewer', 'lead']);
    }

    // ─── Users Collection (RBAC) ──────────────────────────────────────────────

    match /users/{userId} {
      // Users can read their own doc
      allow read: if request.auth != null && request.auth.uid == userId;

      // Lead can read all users
      allow read: if hasRole('lead');

      // Sign-up: user creates own doc with no self-assigned roles
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.status in ['active', 'pending']
                    && request.resource.data.roles.size() == 0
                    && request.resource.data.keys().hasAll(
                         ['email', 'displayName', 'status', 'roles',
                          'appliedRoles', 'applicationNote', 'appliedAt']);

      // Active users can update their own activity and onboarding tracking
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && isActiveUser()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
                         ['lastActiveAt', 'acknowledgedAt', 'onboardingCompleted']);

      // Lead manages users: can update status and roles, but not email or appliedAt
      allow update: if hasRole('lead')
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.appliedAt == resource.data.appliedAt;

      // No deletes (audit trail preserved)
      allow delete: if false;

      // User preferences subcollection — each user can only read/write their own
      match /preferences/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Public Collections ───────────────────────────────────────────────────

    match /signals/{signalId} {
      allow read: if resource.data.status in ['approved', 'edited']
                  || canRead(['signal-reviewer', 'lead']);
      allow write: if canWrite(['signal-reviewer', 'lead']);
    }

    // ─── Pipeline & Archive (server-only write) ──────────────────────────────

    match /_pipeline_health/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /_archive/{document=**} {
      allow read: if canRead(['lead']);
      allow write: if false;
    }

    match /_usage/{document=**} {
      allow read: if canRead(['lead']);
      allow write: if false;
    }

    // ─── Agent-Related Collections ────────────────────────────────────────────

    match /changelogs/{changelogId} {
      allow read: if canRead(['lead']);
      allow write: if false;
    }

    match /agents/{agentId} {
      allow read: if true;
      allow write: if false;
    }

    match /agents/{agentId}/config/{doc} {
      allow read: if isActiveReviewer();
      allow write: if hasRole('lead');
    }

    match /agents/{agentId}/health/{doc} {
      allow read: if isActiveReviewer();
      allow write: if false;
    }

    match /agents/{agentId}/runs/{runId} {
      allow read: if isActiveReviewer();
      allow write: if false;
    }

    // ─── Discovery & Validation Proposals ─────────────────────────────────────

    match /validation_proposals/{docId} {
      allow read: if canRead(['scoring-reviewer', 'lead']);
      allow write: if canWrite(['scoring-reviewer', 'lead']);
    }

    // ─── V2 Graph Model Collections ──────────────────────────────────────────

    match /nodes/{nodeId} {
      allow read: if true;
      allow write: if false; // server-only (Graph Builder)
    }

    match /edges/{edgeId} {
      allow read: if true;
      allow write: if false; // server-only (Graph Builder)
    }

    match /graph_snapshot/{docId} {
      allow read: if true;
      allow write: if false; // server-only (Graph Builder)
    }

    match /node_summaries/{nodeId} {
      allow read: if true;
      allow write: if false; // server-only (Graph Builder)
    }

    match /feed_items/{itemId} {
      allow read: if true;
      allow write: if false; // server-only (Feed Curator)
    }

    match /editorial_hooks/{hookId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['editor', 'lead']);
    }

    // Votes subcollection on nodes
    match /nodes/{nodeId}/votes/{voteId} {
      allow read: if request.auth != null && request.auth.uid == voteId;
      allow create: if request.auth != null
                    && request.auth.uid == voteId
                    && request.resource.data.keys().hasAll(['userId', 'value', 'createdAt'])
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.value in [1, -1];
      allow update: if request.auth != null
                    && request.auth.uid == voteId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['value', 'updatedAt'])
                    && request.resource.data.value in [1, -1];
      allow delete: if request.auth != null && request.auth.uid == voteId;
    }

    match /graph_proposals/{proposalId} {
      allow read: if isActiveReviewer();
      allow write: if hasRole('lead');
    }

    // V2: changelogs become public read (v1 rule above restricts to lead-only)
    match /changelogs/{changelogId} {
      allow read: if true;
    }

  }
}
